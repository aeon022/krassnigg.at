---
// Dateipfad: frontend/src/layouts/BaseLayout.astro
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  noindex?: boolean;
  keywords?: string[];
  schemaOrg?: Record<string, unknown> | Record<string, unknown>[];
}
const {
  title,
  description = "Dr. Helmut Krassnigg - Profil",
  canonicalPath = Astro.url.pathname,
  image,
  noindex = false,
  keywords = [],
  schemaOrg,
} = Astro.props;
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const siteUrl = Astro.site ? new URL(Astro.site) : new URL(Astro.url.origin);
const basePath = import.meta.env.BASE_URL || "/";
const withBase = (path: string) => {
  const normalized = path.startsWith("/") ? path.slice(1) : path;
  if (basePath === "/") return `/${normalized}`;
  return `${basePath}${normalized}`;
};
const canonicalUrl = new URL(withBase(canonicalPath), siteUrl).toString();
const pageTitle = title.includes("Krassnigg") ? title : `${title} | Dr. Helmut Krassnigg`;
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const resolvedImagePath = image
  ? image.startsWith("http://") || image.startsWith("https://")
    ? image
    : withBase(image)
  : undefined;
const socialImageUrl = resolvedImagePath ? new URL(resolvedImagePath, siteUrl).toString() : undefined;
const serializedSchema =
  schemaOrg && (Array.isArray(schemaOrg) ? schemaOrg.length > 0 : true)
    ? JSON.stringify(schemaOrg)
    : undefined;
void keywords;
---

<html lang="de-AT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <ViewTransitions />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Dr. Helmut Krassnigg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Dr. Helmut Krassnigg" />
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    <meta name="twitter:card" content={socialImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <link rel="alternate" hrefLang="de-AT" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700&display=swap"></noscript>
    {serializedSchema && (
      <script type="application/ld+json" set:html={serializedSchema}></script>
    )}
    <style>
      ::view-transition-old(root) {
        animation: page-fade-out 240ms ease both;
      }

      ::view-transition-new(root) {
        animation: page-fade-in 420ms ease both;
      }

      @keyframes page-fade-in {
        from {
          opacity: 0;
          filter: blur(4px);
          transform: scale(0.997);
        }
        to {
          opacity: 1;
          filter: blur(0);
          transform: scale(1);
        }
      }

      @keyframes page-fade-out {
        from {
          opacity: 1;
          filter: blur(0);
          transform: scale(1);
        }
        to {
          opacity: 0;
          filter: blur(2px);
          transform: scale(1.002);
        }
      }
    </style>
  </head>
  <body class="bg-kyoto-bg text-kyoto-text selection:bg-kyoto-accent selection:text-white">
    <Header />

    <slot />
    <Footer />
  </body>
</html>
