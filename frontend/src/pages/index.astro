---
// Dateipfad: frontend/src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, getCollection } from "astro:content";
import Hero from "../components/blocks/Hero.astro";
import ExpertiseBlock from "../components/blocks/ExpertiseBlock.astro";
import ExperienceTimeline from "../components/blocks/ExperienceTimeline.astro";
import Education from "../components/blocks/Education.astro";
import Contact from "../components/blocks/Contact.astro";

const profile = await getEntry("settings", "profile");
const expertiseList = await getCollection("expertise");
const experienceList = await getCollection("experience");
const educationList = await getCollection("education");
const certificationList = await getCollection("certifications");
const profileSectionList = await getCollection("profileSections");
const sortedExpertise = expertiseList.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const sortedExperience = experienceList.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const sortedEducation = educationList.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const sortedCertifications = certificationList.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const sortedProfileSections = profileSectionList.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
const profileStatement = profile?.data.introStatement || "Ich stabilisiere Veränderung in Organisationen — indem ich Führung, Prozesse und Umsetzung präzise aufeinander ausrichte.";
const skillsLine = sortedExpertise.map((item) => item.data.title).join(" · ");
const pageDescription = profile?.data.bio || profileStatement;
const basePath = import.meta.env.BASE_URL || "/";
const siteOrigin = Astro.site ? new URL(Astro.site) : new URL(Astro.url.origin);
const siteBaseUrl = new URL(basePath, siteOrigin).toString();
const seoKeywords = [
  "Helmut Krassnigg",
  "Aftersales",
  "Organisationsentwicklung",
  "Prozessmanagement",
  "Qualitätsmanagement",
  "Digitalisierung",
  "Change Management",
  "Leadership",
];
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile?.data.name || "Dr. Helmut Krassnigg",
  jobTitle: profile?.data.title || "Unternehmensberater",
  description: pageDescription,
  email: profile?.data.contactEmail ? `mailto:${profile.data.contactEmail}` : undefined,
  address: profile?.data.location
    ? {
        "@type": "PostalAddress",
        addressLocality: profile.data.location,
        addressCountry: "AT",
      }
    : undefined,
  url: siteBaseUrl,
  knowsAbout: Array.from(
    new Set([
      ...sortedExpertise.map((item) => item.data.title),
      ...(profile?.data.focusItems || []),
    ])
  ),
  alumniOf: sortedEducation.map((item) => ({
    "@type": "CollegeOrUniversity",
    name: item.data.institution,
    sameAs: item.data.institutionUrl,
  })),
  worksFor: sortedExperience
    .filter((item) => item.data.category === "berufserfahrung")
    .map((item) => ({
      "@type": "Organization",
      name: item.data.company,
      url: item.data.companyUrl,
    })),
};
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Dr. Helmut Krassnigg",
  url: siteBaseUrl,
  inLanguage: "de-AT",
};
---

<style is:global>
  .scroll-fx {
    opacity: 1;
    transform: none;
    filter: none;
  }

  @media (min-width: 768px) and (prefers-reduced-motion: no-preference) {
    .scroll-fx {
      transition: opacity 700ms ease, transform 700ms ease, filter 700ms ease;
      will-change: opacity, transform, filter;
    }

    .js .scroll-fx {
      opacity: 0;
      transform: translateY(30px) scale(0.99);
      filter: blur(4px);
    }

    .js .scroll-fx.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  #profil {
    scroll-margin-top: 1.25rem;
  }

  #profil.hash-focus {
    animation: profil-focus 720ms ease;
  }

  @keyframes profil-focus {
    0% { box-shadow: 0 0 0 0 rgba(84, 120, 110, 0); }
    30% { box-shadow: 0 0 0 12px rgba(84, 120, 110, 0.12); }
    100% { box-shadow: 0 0 0 0 rgba(84, 120, 110, 0); }
  }

  .back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--color-kyoto-accent), transparent 55%);
    padding: 0.6rem 0.9rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-kyoto-accent), black 8%);
    transition: transform 240ms ease, box-shadow 240ms ease, background-color 240ms ease;
  }

  .back-to-top:hover {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--color-kyoto-accent), white 88%);
    box-shadow: 0 12px 24px rgba(61, 74, 62, 0.18);
  }

  .back-to-top .arrow {
    transition: transform 240ms ease;
  }

  .back-to-top:hover .arrow {
    transform: translateY(-2px);
  }
</style>

<BaseLayout
  title={`Dr. Helmut Krassnigg | Curriculum Vitae`}
  description={pageDescription}
  canonicalPath="/"
  image="/og-image.jpg"
  keywords={seoKeywords}
  schemaOrg={[personSchema, websiteSchema]}
>
  <main id="top">
    <div class="max-w-6xl mx-auto px-8 md:px-14 lg:px-20 pb-10 md:pb-12">

      <!-- 1. Hero -->
      <Hero
        name={profile?.data.name}
        title={profile?.data.title}
        bio={profile?.data.bio}
        heroImage={profile?.data.heroImage}
        focusItems={profile?.data.focusItems}
        discoverLabel={profile?.data.discoverLabel}
      />

      <!-- 2. Profile Statement + Skills -->
      <section id="profil" class="scroll-fx grid grid-cols-12 gap-8 md:gap-16 mt-20 md:mt-24">
        <div class="col-span-12 md:col-span-7">
          <h2 class="section-kicker mb-5">Profil</h2>
          <p class="m-0 text-[clamp(1.18rem,2vw,1.72rem)] leading-[1.38] max-w-[34ch]">
            {profileStatement}
          </p>
        </div>
        <div class="col-span-12 md:col-span-5 border-l-shibui pl-6 md:pl-10 self-end">
          <h3 class="section-kicker mb-3">Fachgebiete</h3>
          <p class="m-0 text-sm md:text-[0.94rem] leading-[1.85] text-kyoto-text/80">{skillsLine}</p>
        </div>
      </section>

      {sortedProfileSections.length > 0 && (
        <section id="profil-details" class="scroll-fx mt-14 border-t border-shibui pt-10 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
          {sortedProfileSections.map((item) => (
            <article class="border border-shibui p-5 md:p-6">
              <h3 class="section-kicker mb-3">{item.data.heading}</h3>
              <p class="m-0 text-sm md:text-[0.96rem] leading-[1.8] text-kyoto-text/82 whitespace-pre-line">
                {item.data.content}
              </p>
            </article>
          ))}
        </section>
      )}

      <!-- 3. Experience -->
      <div class="scroll-fx">
        <ExperienceTimeline items={sortedExperience} />
      </div>

      <!-- 4. Education -->
      <div class="scroll-fx">
        <Education
          degrees={sortedEducation}
          certifications={sortedCertifications}
        />
      </div>

      <!-- 5. Expertise Cards -->
      <section id="expertise" class="scroll-fx mt-20 border-t border-shibui pt-10">
        <h2 class="section-kicker mb-6">Expertise</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {sortedExpertise.map((item) => (
            <ExpertiseBlock expertise={item} />
          ))}
        </div>
      </section>

      <!-- 6. Contact -->
      <div class="scroll-fx">
        <Contact
          email={profile?.data.contactEmail}
          location={profile?.data.location}
          socialLinks={profile?.data.socialLinks}
        />
      </div>

      <div class="mt-10 md:mt-12 flex justify-end">
        <a href="#top" class="back-to-top" data-back-to-top>
          <span class="arrow" aria-hidden="true">↑</span>
          Nach oben
        </a>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

  const animateScrollTo = (targetY, duration = 820) => {
    const clampedTarget = Math.max(
      0,
      Math.min(targetY, document.documentElement.scrollHeight - window.innerHeight)
    );

    if (duration <= 0) {
      window.scrollTo(0, clampedTarget);
      return;
    }

    const startY = window.scrollY;
    const distance = clampedTarget - startY;
    if (Math.abs(distance) < 2) return;

    const previousRaf = window.__krassniggScrollRaf;
    if (previousRaf) cancelAnimationFrame(previousRaf);

    const startTime = performance.now();
    const tick = (now) => {
      const elapsed = now - startTime;
      const progress = Math.min(1, elapsed / duration);
      const eased = easeInOutCubic(progress);
      window.scrollTo(0, startY + distance * eased);
      if (progress < 1) {
        window.__krassniggScrollRaf = requestAnimationFrame(tick);
      } else {
        window.__krassniggScrollRaf = null;
      }
    };

    window.__krassniggScrollRaf = requestAnimationFrame(tick);
  };

  const smoothScrollToProfil = () => {
    const profilSection = document.getElementById("profil");
    if (!(profilSection instanceof HTMLElement)) return;
    const targetY = window.scrollY + profilSection.getBoundingClientRect().top - 20;
    animateScrollTo(targetY, 860);
    profilSection.classList.remove("hash-focus");
    requestAnimationFrame(() => profilSection.classList.add("hash-focus"));
  };

  const smoothBindKey = "__krassniggProfilSmoothBound";
  if (!(window)[smoothBindKey]) {
    document.addEventListener("click", (event) => {
      const clicked =
        event.target instanceof Element
          ? event.target
          : event.target instanceof Node
            ? event.target.parentElement
            : null;
      if (!(clicked instanceof Element)) return;
      const anchor = clicked.closest("a[href]");
      if (!(anchor instanceof HTMLAnchorElement)) return;

      const url = new URL(anchor.href, window.location.href);
      const samePath =
        url.pathname.replace(/\/+$/, "") === window.location.pathname.replace(/\/+$/, "");
      if (!samePath || url.hash !== "#profil") return;

      event.preventDefault();
      if (window.location.hash !== "#profil") {
        history.replaceState(null, "", `${window.location.pathname}${window.location.search}#profil`);
      }
      smoothScrollToProfil();
    });
    window[smoothBindKey] = true;
  }

  const initBackToTopLinks = () => {
    document.querySelectorAll("[data-back-to-top]").forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      if (link.dataset.boundBackToTop === "true") return;
      link.dataset.boundBackToTop = "true";

      link.addEventListener("click", (event) => {
        event.preventDefault();
        link.animate(
          [
            { transform: "translateY(0)", opacity: 1 },
            { transform: "translateY(-6px)", opacity: 0.82 },
            { transform: "translateY(0)", opacity: 1 },
          ],
          { duration: 360, easing: "cubic-bezier(0.22, 0.8, 0.2, 1)" }
        );
        animateScrollTo(0, 980);
      });
    });
  };
  initBackToTopLinks();
  document.addEventListener("astro:page-load", initBackToTopLinks);

  if (window.location.hash === "#profil") {
    window.scrollTo({ top: 0, left: 0, behavior: "auto" });
    setTimeout(smoothScrollToProfil, 60);
  }

  const enableDesktopScrollFx =
    typeof window !== "undefined" &&
    window.matchMedia("(min-width: 768px)").matches &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (enableDesktopScrollFx) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.2,
        rootMargin: "0px 0px -8% 0px",
      }
    );

    document.querySelectorAll(".scroll-fx").forEach((section) => {
      observer.observe(section);
      if (section.getBoundingClientRect().top < window.innerHeight * 0.85) {
        section.classList.add("is-visible");
      }
    });
  }
</script>
