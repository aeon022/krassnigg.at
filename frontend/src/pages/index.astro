---
// Dateipfad: frontend/src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry, getCollection } from "astro:content";
import Hero from "../components/blocks/Hero.astro";
import ExpertiseBlock from "../components/ExpertiseBlock.astro";
import Contact from "../components/blocks/Contact.astro";

const profile = await getEntry("settings", "profile");
const expertiseList = await getCollection("expertise");
const sortedExpertise = expertiseList.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<BaseLayout title={`Dr. Helmut Krassnigg | ${profile?.data.title}`}>
  <main>
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <Hero 
        name={profile?.data.name} 
        title={profile?.data.title} 
        bio={profile?.data.bio}
        heroImage={profile?.data.heroImage} 
      />
    </div>
    
    <div class="bg-kyoto-light-gray">
      <section id="expertise" class="py-32 max-w-7xl mx-auto px-6 md:px-12">
        <div class="text-center mb-20">
          <h2 class="text-5xl font-bold font-serif">Expertise & Tätigkeitsbereiche</h2>
          <p class="text-xl text-kyoto-sub mt-6 max-w-3xl mx-auto">
            Strukturierte Begleitung und Prozessoptimierung für nachhaltige unternehmerische Resilienz.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {sortedExpertise.map((item) => (
            <ExpertiseBlock expertise={item.data} />
          ))}
        </div>
      </section>
    </div>

    <Contact 
      email={profile?.data.contactEmail} 
      location={profile?.data.location} 
    />
  </main>
</BaseLayout>