---
const basePath = import.meta.env.BASE_URL || "/";
const withBase = (path: string) => {
  const normalized = path.startsWith("/") ? path.slice(1) : path;
  if (basePath === "/") return `/${normalized}`;
  return `${basePath}${normalized}`;
};
---

<footer class="border-t border-shibui py-10">
  <div class="max-w-6xl mx-auto px-6 md:px-14 lg:px-20 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <p class="text-xs uppercase tracking-[0.14em] text-kyoto-sub">&copy; {new Date().getFullYear()} Dr. Helmut Krassnigg. Alle Rechte vorbehalten.</p>
    <nav aria-label="Rechtliches" class="flex items-center gap-4 text-[0.72rem] uppercase tracking-[0.12em]">
      <a href={withBase("/impressum")} class="text-kyoto-sub hover:text-kyoto-accent transition-colors">Impressum</a>
      <a href={withBase("/datenschutz")} class="text-kyoto-sub hover:text-kyoto-accent transition-colors">Datenschutz</a>
    </nav>
  </div>
</footer>
