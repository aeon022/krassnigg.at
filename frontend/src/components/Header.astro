---
import { getEntry } from "astro:content";

const basePath = import.meta.env.BASE_URL || "/";
const withBase = (path: string) => {
  const normalized = path.startsWith("/") ? path.slice(1) : path;
  if (basePath === "/") return `/${normalized}`;
  return `${basePath}${normalized}`;
};
const stripBase = (path: string) => {
  if (basePath === "/") return path;
  const stripped = path.startsWith(basePath) ? `/${path.slice(basePath.length)}` : path;
  return stripped.length > 1 ? stripped.replace(/\/+$/, "") : stripped;
};
const currentPath = stripBase(Astro.url.pathname);
const isActive = (path: string) => currentPath === path;
const profile = await getEntry("settings", "profile");
const contactEmail = profile?.data.contactEmail ?? "helmut@krassnigg.at";
const socialLinks = profile?.data.socialLinks ?? {};
const socialEntries = [
  { key: "linkedin", label: "LinkedIn" },
  { key: "facebook", label: "Facebook" },
  { key: "instagram", label: "Instagram" },
  { key: "x", label: "X" },
  { key: "bluesky", label: "Bluesky" },
  { key: "youtube", label: "YouTube" },
]
  .map((item) => ({ ...item, href: socialLinks[item.key as keyof typeof socialLinks] }))
  .filter((item) => typeof item.href === "string" && item.href.length > 0);
---

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 60;
    pointer-events: none;
  }

  .menu-shell {
    position: fixed;
    top: 0.95rem;
    right: 0.95rem;
    pointer-events: auto;
  }

  .brand-shell {
    position: fixed;
    top: 0.95rem;
    left: 0.95rem;
    pointer-events: auto;
  }

  .brand-chip {
    color: var(--color-text-soft);
    display: inline-flex;
    align-items: center;
    padding: 0;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.64rem;
    text-decoration: none;
    transition: color 220ms ease;
  }

  .brand-chip:hover {
    color: var(--color-accent);
  }

  .menu-toggle {
    background: color-mix(in srgb, var(--color-bg), transparent 14%);
    border: 1px solid color-mix(in srgb, var(--color-ink), transparent 70%);
    color: var(--color-text-soft);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    padding: 0.48rem 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.66rem;
    border-radius: 999px;
    backdrop-filter: blur(7px);
    box-shadow: 0 8px 24px color-mix(in srgb, black, transparent 86%);
    transition: color 220ms ease, border-color 220ms ease, background-color 220ms ease;
  }

  .menu-toggle:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 38%);
    background: color-mix(in srgb, var(--color-bg), var(--color-accent-soft) 10%);
  }

  .menu-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-ink), transparent 78%);
    background: color-mix(in srgb, var(--color-bg), transparent 8%);
  }

  .burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 3px;
    width: 0.78rem;
  }

  .burger-line {
    width: 100%;
    height: 1px;
    background: currentColor;
    transform-origin: center;
    transition: transform 260ms ease, opacity 220ms ease;
  }

  .menu-shell[data-open="true"] .burger-line:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .menu-shell[data-open="true"] .burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0.25);
  }

  .menu-shell[data-open="true"] .burger-line:nth-child(3) {
    transform: translateY(-4px) rotate(-45deg);
  }

  .offcanvas-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(88vw, 25rem);
    z-index: 58;
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--color-bg), var(--color-surface) 35%) 0%,
      color-mix(in srgb, var(--color-bg), var(--color-muted-teal-50) 28%) 100%
    );
    transform: translateX(100%) rotateY(-88deg);
    transform-origin: left center;
    transition: transform 420ms cubic-bezier(0.22, 0.85, 0.25, 1), box-shadow 360ms ease;
    box-shadow: -22px 0 42px rgba(0, 0, 0, 0.2);
    padding: 5.2rem 1.5rem 1.5rem;
  }

  .menu-shell[data-open="true"] .offcanvas-panel {
    transform: translateX(0) rotateY(0deg);
  }

  .offcanvas-close {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--color-ink), transparent 72%);
    background: color-mix(in srgb, var(--color-bg), transparent 6%);
    color: var(--color-text-soft);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.44rem 0.6rem;
    border-radius: 999px;
    cursor: pointer;
    transition: color 220ms ease, border-color 220ms ease;
  }

  .offcanvas-close:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 45%);
  }

  .nav-label {
    margin: 0 0 1.2rem;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .panel-brand {
    margin: 0 0 0.18rem;
    font-size: 1.08rem;
    line-height: 1.16;
    color: var(--color-text);
  }

  .panel-sub {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.38;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--color-text-soft), transparent 8%);
    max-width: 28ch;
  }

  .panel-highlight {
    margin: 0.62rem 0 0;
    padding: 0.16rem 0 0.1rem;
    font-size: 0.71rem;
    line-height: 1.35;
    letter-spacing: 0.01em;
    color: var(--color-accent);
    display: inline-block;
  }

  .offcanvas-content {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .offcanvas-top {
    margin-bottom: 1rem;
  }

  .offcanvas-main {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-row {
    display: block;
  }

  .nav-links {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .menu-link {
    opacity: 0;
    transform: translateX(12px);
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding: 0.58rem 0.55rem;
    transition: transform 240ms ease, opacity 240ms ease, color 220ms ease, background-color 220ms ease;
  }

  .menu-link.is-main {
    margin-top: 0.22rem;
  }

  .menu-link.is-sub {
    margin-left: 0.85rem;
    font-size: 0.82rem;
    color: var(--color-text-soft);
    padding-top: 0.45rem;
    padding-bottom: 0.45rem;
  }

  .menu-shell[data-open="true"] .menu-link {
    opacity: 1;
    transform: translateX(0);
  }

  .menu-shell[data-open="true"] .menu-link:nth-child(1) { transition-delay: 70ms; }
  .menu-shell[data-open="true"] .menu-link:nth-child(2) { transition-delay: 95ms; }
  .menu-shell[data-open="true"] .menu-link:nth-child(3) { transition-delay: 120ms; }
  .menu-shell[data-open="true"] .menu-link:nth-child(4) { transition-delay: 145ms; }
  .menu-shell[data-open="true"] .menu-link:nth-child(5) { transition-delay: 170ms; }
  .menu-shell[data-open="true"] .menu-link:nth-child(6) { transition-delay: 195ms; }

  .menu-link:hover {
    color: var(--color-accent);
    background: transparent;
    border-bottom-color: color-mix(in srgb, var(--color-accent), transparent 26%);
    transform: translateX(2px);
  }

  .menu-link.active {
    color: var(--color-accent);
    font-weight: 700;
    background: transparent;
    border-bottom-color: color-mix(in srgb, var(--color-accent), transparent 10%);
    border-bottom-width: 2px;
  }

  .offcanvas-bottom {
    margin-top: auto;
    padding-top: 0.9rem;
  }

  .panel-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.9rem;
    margin-bottom: 0.95rem;
  }

  .legal-link {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 0.1rem;
    transition: color 220ms ease, border-color 220ms ease;
  }

  .legal-link:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 38%);
  }

  .panel-contact {
    padding-top: 1rem;
  }

  .panel-contact-label {
    margin: 0 0 0.52rem;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .panel-contact a {
    display: inline-flex;
    align-items: center;
    margin-right: 0.75rem;
    margin-bottom: 0.45rem;
    color: var(--color-text-soft);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink), transparent 80%);
    padding-bottom: 0.12rem;
    font-size: 0.82rem;
    transition: color 220ms ease, border-color 220ms ease;
  }

  .panel-contact a:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 38%);
  }

  .panel-social {
    margin-top: 0.55rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.45rem;
  }

  .panel-social-link {
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.22rem 0.4rem;
    border: 1px solid color-mix(in srgb, var(--color-ink), transparent 82%);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 220ms ease, border-color 220ms ease, background-color 220ms ease;
  }

  .panel-social-link:hover {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent), transparent 40%);
    background: color-mix(in srgb, var(--color-accent), transparent 94%);
  }

  @media (prefers-reduced-motion: reduce) {
    .burger-line,
    .offcanvas-panel,
    .menu-link {
      transition: none;
    }
  }
</style>

<header class="site-header">
  <div class="brand-shell">
    <a href={withBase("/")} class="brand-chip" aria-label="Zur Startseite">
      Dr. Helmut Krassnigg
    </a>
  </div>

  <div class="menu-shell" data-open="false">
    <button class="menu-toggle" type="button" aria-label="Navigation öffnen" aria-expanded="false" aria-controls="main-nav-panel">
      <span class="menu-badge" aria-hidden="true">
        <span class="burger" aria-hidden="true">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </span>
      </span>
      Menü
    </button>

    <nav id="main-nav-panel" class="offcanvas-panel" aria-label="Hauptnavigation">
      <button class="offcanvas-close" type="button" aria-label="Navigation schließen">Schließen</button>
      <div class="offcanvas-content">
        <div class="offcanvas-top">
          <p class="nav-label">Navigation</p>
          <h2 class="panel-brand font-serif">Dr. Helmut Krassnigg</h2>
          <p class="panel-sub">Organisationsentwicklung, Aftersales, Leadership.</p>
          <p class="panel-highlight">Klar in der Strategie, präzise in der Umsetzung.</p>
        </div>

        <div class="offcanvas-main">
          <div class="nav-row">
            <div class="nav-links">
              <a class:list={["menu-link is-main", { active: isActive("/") }]} href={withBase("/")}>Startseite</a>
              <a class="menu-link is-sub" href={isActive("/") ? "#profil" : withBase("/#profil")}>Profil</a>
              <a class="menu-link is-sub" href={withBase("/experience")}>Beruflicher Werdegang</a>
              <a class="menu-link is-sub" href={withBase("/education")}>Ausbildung</a>
              <a class="menu-link is-sub" href={withBase("/certifications")}>Zertifizierungen</a>
              <a class="menu-link is-sub" href={withBase("/expertise")}>Expertise</a>
              <a class:list={["menu-link is-main", { active: isActive("/kontakt") }]} href={withBase("/kontakt")}>Kontakt</a>
            </div>
          </div>
        </div>

        <div class="offcanvas-bottom">
          <div class="panel-legal" aria-label="Rechtliches">
            <a class="legal-link" href={withBase("/impressum")}>Impressum</a>
            <a class="legal-link" href={withBase("/datenschutz")}>Datenschutz</a>
          </div>

          <section class="panel-contact" aria-label="Kontaktkurzinfo">
            <p class="panel-contact-label">Kontakt</p>
            <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
            {socialEntries.length > 0 && (
              <div class="panel-social" aria-label="Social Links">
                {socialEntries.map((item) => (
                  <a class="panel-social-link" href={item.href} target="_blank" rel="noopener noreferrer me">
                    {item.label}
                  </a>
                ))}
              </div>
            )}
          </section>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  import { initHeaderMenu } from "../assets/menu.js";
  initHeaderMenu();
  document.addEventListener("astro:page-load", initHeaderMenu);
</script>
