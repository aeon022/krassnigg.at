---
// Dateipfad: frontend/src/components/blocks/Contact.astro
const { email, location, socialLinks = {} } = Astro.props;

const socialEntries = [
  { key: "linkedin", label: "LinkedIn" },
  { key: "facebook", label: "Facebook" },
  { key: "instagram", label: "Instagram" },
  { key: "x", label: "X" },
  { key: "bluesky", label: "Bluesky" },
  { key: "youtube", label: "YouTube" },
]
  .map((item) => ({ ...item, href: socialLinks?.[item.key] }))
  .filter((item) => typeof item.href === "string" && item.href.length > 0);
---

<section id="kontakt" class="mt-20 border-t border-shibui pt-10">
  <h2 class="section-kicker mb-4">Kontakt</h2>
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
    <div>
      <p class="m-0 text-base md:text-lg text-kyoto-text/85">Für Anfragen zu Coaching, Trainings und Prozessbegleitung.</p>
      <p class="m-0 mt-2 text-sm text-kyoto-sub uppercase tracking-[0.14em]">{location}</p>
    </div>
    <div class="flex flex-wrap items-center gap-2.5">
      <a href={`mailto:${email}`} class="inline-flex items-center border border-shibui px-4 py-2.5 text-sm md:text-base tracking-[0.04em] hover:text-kyoto-accent hover:border-kyoto-accent/50 transition-colors">
        {email}
      </a>
      <a
        href="https://www.bornemannundpartner.at"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center border border-shibui px-4 py-2.5 text-sm md:text-base tracking-[0.04em] hover:text-kyoto-accent hover:border-kyoto-accent/50 transition-colors"
      >
        bornemannundpartner.at
      </a>
    </div>
  </div>

  {socialEntries.length > 0 && (
    <div class="mt-6 flex flex-wrap items-center gap-2.5">
      {socialEntries.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener noreferrer me"
          class="inline-flex items-center gap-1.5 border border-shibui px-3 py-1.5 text-[0.72rem] uppercase tracking-[0.12em] text-kyoto-sub hover:text-kyoto-accent hover:border-kyoto-accent/50 transition-colors"
          aria-label={`${social.label} Profil`}
        >
          {social.key === "linkedin" && (
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
              <path d="M6.94 8.5a1.56 1.56 0 1 1 0-3.12 1.56 1.56 0 0 1 0 3.12ZM5.6 9.8h2.7V18H5.6V9.8Zm4.33 0h2.6v1.12h.04c.36-.69 1.25-1.42 2.57-1.42 2.75 0 3.26 1.81 3.26 4.16V18h-2.7v-3.84c0-.92-.02-2.11-1.29-2.11-1.3 0-1.5 1.01-1.5 2.05V18h-2.7V9.8Z"/>
            </svg>
          )}
          {social.key === "facebook" && (
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
              <path d="M13.5 21v-7h2.3l.34-2.73H13.5V9.53c0-.8.22-1.34 1.35-1.34h1.44V5.74c-.25-.03-1.12-.1-2.12-.1-2.1 0-3.53 1.28-3.53 3.64v2h-2.37V14h2.37v7h2.86Z"/>
            </svg>
          )}
          {social.key === "instagram" && (
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
              <circle cx="12" cy="12" r="4.1"></circle>
              <circle cx="17.2" cy="6.8" r="1"></circle>
            </svg>
          )}
          {social.key === "x" && (
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
              <path d="M18.9 4h-2.6l-3.2 3.7L10.3 4H4.7l5.5 7.8L4.4 20H7l4.3-5 3.5 5h5.6l-5.8-8.2L18.9 4Zm-3.2 14-8-11.3h1.6l8 11.3h-1.6Z"/>
            </svg>
          )}
          {social.key === "bluesky" && (
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
              <path d="M12 11.5c1.6-2.5 3.6-4.7 5.7-6.2 1.5-1 3.8-1.8 3.8.8 0 2.6-1.3 5.1-3.8 6.3-1 .5-2.2.8-3.4.9.6.6 1.5 1.1 2.1 1.8 1 1 1.7 2.3 1.7 3.8 0 2.5-2 2.7-3.7 1.8-1-.6-1.8-1.7-2.4-2.7-.6 1-1.4 2.1-2.4 2.7-1.7.9-3.7.7-3.7-1.8 0-1.5.7-2.8 1.7-3.8.6-.7 1.5-1.2 2.1-1.8-1.2-.1-2.4-.4-3.4-.9C3.8 11.2 2.5 8.7 2.5 6.1c0-2.6 2.3-1.8 3.8-.8 2.1 1.5 4.1 3.7 5.7 6.2Z"/>
            </svg>
          )}
          {social.key === "youtube" && (
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
              <path d="M21.1 8.2a2.8 2.8 0 0 0-2-2c-1.8-.5-9.1-.5-9.1-.5s-7.3 0-9.1.5a2.8 2.8 0 0 0-2 2C-1.6 10 0 12 0 12s-1.6 2 .9 3.8a2.8 2.8 0 0 0 2 2c1.8.5 9.1.5 9.1.5s7.3 0 9.1-.5a2.8 2.8 0 0 0 2-2C24.6 14 23 12 23 12s1.6-2-.9-3.8ZM9.3 15.3V8.7L15.2 12l-5.9 3.3Z"/>
            </svg>
          )}
          {social.label}
        </a>
      ))}
    </div>
  )}
</section>
