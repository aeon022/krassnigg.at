---
// Dateipfad: frontend/src/components/blocks/Contact.astro
const { email, location } = Astro.props;
---
<section class="py-32 bg-white text-center">
  <div class="max-w-4xl mx-auto px-6 md:px-12">
    <h2 class="text-5xl font-bold font-serif mb-6">In Kontakt treten</h2>
    <p class="text-xl text-kyoto-sub mb-10">
      Ich freue mich auf Ihre Anfrage und eine mögliche Zusammenarbeit.
    </p>
    <a href={`mailto:${email}`} class="text-3xl text-kyoto-accent hover:underline font-serif font-bold">
      {email}
    </a>
    <p class="text-lg text-kyoto-sub mt-6">{location}</p>
  </div>
</section>