---
// Dateipfad: frontend/src/components/blocks/Hero.astro
const { name, title, bio } = Astro.props;
---
<section class="min-h-[80vh] flex flex-col justify-center py-20">
  <div class="space-y-6">
    <h1 class="text-6xl md:text-8xl font-serif leading-none tracking-tighter">
      {name}
    </h1>
    <h2 class="text-2xl md:text-3xl font-light text-kyoto-accent italic opacity-90">
      {title}
    </h2>
    <div class="h-px w-24 bg-kyoto-accent/30 my-8"></div>
    <p class="max-w-2xl text-xl text-kyoto-sub leading-relaxed font-light">
      {bio}
    </p>
  </div>
</section>