---
// Dateipfad: frontend/src/components/blocks/Hero.astro
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
const { name, title, bio, heroImage } = Astro.props;
const localProfileImages = import.meta.glob('../../assets/images/profile/*', {
  eager: true,
  import: 'default',
}) as Record<string, ImageMetadata>;

let resolvedHeroImage: ImageMetadata | string | undefined;

if (typeof heroImage === 'string') {
  resolvedHeroImage = heroImage.startsWith('../../assets/images/profile/')
    ? localProfileImages[heroImage]
    : heroImage;
} else {
  resolvedHeroImage = heroImage;
}
---
<section class="min-h-[75vh] flex items-center py-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="space-y-8">
      <div class="space-y-2">
        <span class="text-kyoto-accent font-medium tracking-[0.25em] uppercase text-xs">Unternehmensberatung</span>
        <h1 class="text-6xl md:text-8xl font-serif leading-[0.9] tracking-tighter">
          {name}
        </h1>
      </div>
      <h2 class="text-2xl md:text-3xl font-light text-kyoto-accent italic opacity-90 font-serif">
        {title}
      </h2>
      <div class="h-px w-32 bg-kyoto-accent/20 my-10"></div>
      <p class="max-w-2xl text-xl text-kyoto-sub leading-relaxed font-light">
        {bio}
      </p>
    </div>
    {resolvedHeroImage && (
      <div class="flex justify-center">
        {typeof resolvedHeroImage === 'string' ? (
          <img
            src={resolvedHeroImage}
            alt={name}
            width="400"
            height="600"
            loading="lazy"
            decoding="async"
            class="rounded-lg shadow-xl object-cover"
          />
        ) : (
          <Image
            src={resolvedHeroImage}
            alt={name}
            width={400}
            height={600}
            class="rounded-lg shadow-xl object-cover"
          />
        )}
      </div>
    )}
  </div>
</section>
