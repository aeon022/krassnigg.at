---
// Dateipfad: frontend/src/components/blocks/Hero.astro
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
const { name, title, bio, heroImage } = Astro.props;
const localProfileImages = import.meta.glob('../../assets/images/profile/*', {
  eager: true,
  import: 'default',
}) as Record<string, ImageMetadata>;

let resolvedHeroImage: ImageMetadata | string | undefined;

if (typeof heroImage === 'string') {
  resolvedHeroImage = heroImage.startsWith('../../assets/images/profile/')
    ? localProfileImages[heroImage]
    : heroImage;
} else {
  resolvedHeroImage = heroImage;
}
---
<section class="py-40 bg-kyoto-light-gray">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">
      <div class="space-y-8">
        <h1 class="text-7xl font-bold font-serif leading-tight">
          {name}
        </h1>
        <h2 class="text-3xl font-medium text-kyoto-accent font-serif">
          {title}
        </h2>
        <p class="max-w-xl text-xl text-kyoto-sub leading-relaxed">
          {bio}
        </p>
      </div>
      {resolvedHeroImage && (
        <div class="flex justify-center">
          {typeof resolvedHeroImage === 'string' ? (
            <img
              src={resolvedHeroImage}
              alt={name}
              width="400"
              height="600"
              loading="lazy"
              decoding="async"
              class="rounded-lg object-cover shadow-2xl"
            />
          ) : (
            <Image
              src={resolvedHeroImage}
              alt={name}
              width={400}
              height={600}
              class="rounded-lg object-cover shadow-2xl"
            />
          )}
        </div>
      )}
    </div>
  </div>
</section>
