---
// Dateipfad: frontend/src/components/blocks/Hero.astro
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const { name, title, bio, heroImage, focusItems = [], discoverLabel = "Entdecken" } = Astro.props;

const heroIntro = typeof bio === "string" ? bio.trim() : "";
const heroFocusItems = Array.isArray(focusItems) ? focusItems.filter((item) => typeof item === "string" && item.trim()) : [];

const localProfileImages = import.meta.glob("../../assets/images/profile/*", {
  eager: true,
  import: "default",
}) as Record<string, ImageMetadata>;

let resolvedHeroImage: ImageMetadata | string | undefined;
if (typeof heroImage === "string") {
  resolvedHeroImage = heroImage.startsWith("../../assets/images/profile/")
    ? localProfileImages[heroImage]
    : heroImage;
} else {
  resolvedHeroImage = heroImage;
}

const hasImage = !!resolvedHeroImage;
---

<style>
  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
    background: radial-gradient(circle at 30% 30%, #fdfcfb 0%, #f7f5f2 100%);
  }

  .kyoto-fog {
    position: absolute;
    inset: -14%;
    pointer-events: none;
    filter: blur(64px);
    opacity: 0.92;
    background:
      radial-gradient(circle at 14% 22%, rgba(61, 74, 62, 0.3) 0%, rgba(61, 74, 62, 0) 48%),
      radial-gradient(circle at 84% 24%, rgba(62, 154, 147, 0.22) 0%, rgba(62, 154, 147, 0) 56%),
      radial-gradient(circle at 56% 80%, rgba(111, 123, 102, 0.2) 0%, rgba(111, 123, 102, 0) 54%);
    mix-blend-mode: normal;
    animation: kyoto-fog-drift 24s ease-in-out infinite alternate;
    z-index: 0;
  }

  .kyoto-fog::after {
    content: "";
    position: absolute;
    inset: -12%;
    background:
      radial-gradient(circle at 32% 58%, rgba(253, 252, 251, 0.4) 0%, rgba(253, 252, 251, 0) 60%),
      radial-gradient(circle at 72% 42%, rgba(61, 74, 62, 0.16) 0%, rgba(61, 74, 62, 0) 50%);
    animation: kyoto-fog-shift 30s ease-in-out infinite alternate-reverse;
  }

  .grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.03;
    background-image: linear-gradient(var(--color-kyoto-accent) 0.5px, transparent 0.5px),
      linear-gradient(90deg, var(--color-kyoto-accent) 0.5px, transparent 0.5px);
    background-size: 100px 100px;
    z-index: 1;
  }

  .hero-title-wrap:hover .hero-name {
    color: color-mix(in srgb, var(--color-kyoto-text), var(--color-kyoto-accent) 12%);
    letter-spacing: 0;
    text-shadow: 0 8px 26px rgba(61, 74, 62, 0.14);
  }

  .hero-name {
    transition: color 420ms ease, letter-spacing 420ms ease, text-shadow 420ms ease;
  }

  .hero-description {
    text-wrap: pretty;
    white-space: pre-line;
    max-width: 48ch;
  }

  .scroll-cta:hover .scroll-line-shell {
    background-color: color-mix(in srgb, var(--color-pearl-aqua-500), transparent 68%);
    box-shadow: 0 0 14px color-mix(in srgb, var(--color-pearl-aqua-500), transparent 40%);
  }

  .scroll-cta:hover .scroll-line-fill {
    transform: scaleY(1.18);
    opacity: 1;
    background: var(--color-pearl-aqua-500);
  }

  .scroll-cta:hover .scroll-cta-label {
    color: var(--color-pearl-aqua-600);
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-pearl-aqua-400), transparent 35%);
  }

  .scroll-line-fill {
    transition: transform 340ms ease, opacity 340ms ease;
    opacity: 0.9;
    animation: cta-light-pulse 2.6s ease-in-out infinite;
  }

  .scroll-cta-label {
    animation: cta-label-fade 2.6s ease-in-out infinite;
    transition: color 300ms ease, text-shadow 300ms ease;
  }

  .scroll-line-shell {
    transition: background-color 300ms ease, box-shadow 300ms ease;
  }

  @keyframes cta-label-fade {
    0%, 100% { opacity: 0.45; }
    50% { opacity: 1; }
  }

  @keyframes cta-light-pulse {
    0%, 100% { opacity: 0.42; transform: scaleY(0.88); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  @keyframes kyoto-fog-drift {
    from { transform: translate(-3%, -2%) scale(1); }
    to { transform: translate(4%, 3%) scale(1.08); }
  }

  @keyframes kyoto-fog-shift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(-3%, 2%) scale(1.06); }
  }
</style>

<div class="hero-background">
  <div class="kyoto-fog" aria-hidden="true"></div>
  <div class="grid-overlay"></div>
</div>

<section
  class="grid grid-cols-12 gap-0 h-screen min-h-[600px] border-b border-shibui relative"
  style="border-top: 2px solid var(--color-kyoto-accent);"
>
  <div class={`col-span-12 ${hasImage ? 'md:col-span-8' : ''} flex flex-col px-6 md:px-12 relative z-10`}>

    <div class="pt-10 md:pt-14">
      <p class="font-sans text-[10px] uppercase tracking-[0.28em] text-kyoto-accent">
        Profil
      </p>
    </div>

    <div class="hero-title-wrap flex-1 flex flex-col justify-end pb-7 md:pb-9">
      <p class="m-0 mb-2.5 font-sans text-[0.72rem] text-kyoto-sub tracking-[0.04em]">
        {title}
      </p>
      <h1 class="hero-name m-0 font-serif text-[clamp(1.9rem,4vw,4.5rem)] leading-[1.06] tracking-[-0.01em] text-kyoto-text">
        {name}
      </h1>
    </div>

    <div class="border-t border-kyoto-accent/10"></div>

    {hasImage && (
      <div class="md:hidden mt-5 mb-2 overflow-hidden border border-kyoto-accent/10 relative">
        <Image
          src={resolvedHeroImage as ImageMetadata}
          alt={name + " - " + title}
          width={1200}
          height={800}
          quality="high"
          class="w-full h-[38vh] min-h-[220px] max-h-[340px] object-cover grayscale-[0.2]"
          loading="eager"
        />
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] py-7 md:py-9 items-center">
      <p class="hero-description m-0 text-[0.95rem] md:text-[1.05rem] leading-[1.8] text-kyoto-text/80">
        {heroIntro}
      </p>
      <ul class="hidden md:flex flex-col justify-center gap-2 border-l border-kyoto-accent/10 pl-10 m-0 p-0">
        {heroFocusItems.map((f) => (
          <li class="list-none font-sans text-[0.65rem] uppercase tracking-[0.15em] text-kyoto-sub">
            {f}
          </li>
        ))}
      </ul>
    </div>

    <div class="pb-8 md:pb-10">
      <a
        href="#profil"
        class="scroll-cta inline-flex flex-col items-start gap-2 text-kyoto-accent/70 hover:text-kyoto-accent transition-all duration-500 group"
      >
        <span class="scroll-cta-label font-sans text-[0.6rem] uppercase tracking-[0.3em]">{discoverLabel}</span>
        <div class="scroll-line-shell w-[1px] h-12 bg-kyoto-accent/20 overflow-hidden relative transition-colors duration-300">
          <div class="scroll-line-fill absolute top-0 left-0 w-full h-full bg-kyoto-accent origin-top animate-scroll-line"></div>
        </div>
      </a>
    </div>
  </div>

  {hasImage && (
    <div class="hidden md:block md:col-span-4 border-l border-kyoto-accent/10 overflow-hidden relative z-10">
      <Image
        src={resolvedHeroImage as ImageMetadata}
        alt={name + " - " + title}
        width={800}
        height={1200}
        quality="high"
        class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-1000"
        loading="eager"
      />
    </div>
  )}
</section>
