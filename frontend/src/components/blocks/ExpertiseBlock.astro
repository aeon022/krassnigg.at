---
import type { CollectionEntry } from "astro:content";

interface Props {
  expertise: CollectionEntry<"expertise">;
}

const { expertise } = Astro.props;
const { id, data } = expertise;
const basePath = import.meta.env.BASE_URL || "/";
const withBase = (path: string) => {
  const normalized = path.startsWith("/") ? path.slice(1) : path;
  if (basePath === "/") return `/${normalized}`;
  return `${basePath}${normalized}`;
};
---

<a href={withBase(`/expertise/${id}`)} class="block h-full hover:bg-shibui/20 transition-colors duration-300">
<article class="border border-shibui p-5 md:p-6 h-full bg-transparent">
  <h3 class="font-serif text-[1.28rem] leading-[1.25] mb-3">{data.title}</h3>
  <p class="text-sm md:text-[0.95rem] leading-[1.7] text-kyoto-text/80">{data.description}</p>
</article>
</a>
