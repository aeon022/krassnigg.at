---
import type { CollectionEntry } from "astro:content";

interface Props {
  degrees: CollectionEntry<"education">["data"][];
  certifications: CollectionEntry<"certifications">["data"][];
}

const { degrees = [], certifications = [] } = Astro.props as Props;
---

<section id="education" class="mt-20 border-t border-shibui pt-10">
  <h2 class="section-kicker mb-6">Ausbildung</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-0">
    <!-- Degrees -->
    <div>
      {degrees.map((item, i) => (
        <div class={`grid grid-cols-[56px_1fr] gap-6 py-5 ${i < degrees.length - 1 ? 'border-b border-shibui' : ''}`}>
          <p class="m-0 font-sans text-[11px] tracking-[0.1em] text-kyoto-sub font-semibold pt-0.5">{item.year}</p>
          <div>
            <p class="m-0 font-serif text-[clamp(0.95rem,1.4vw,1.1rem)] leading-[1.25]">{item.degree}</p>
            <p class="m-0 mt-1 font-sans text-[0.8rem] tracking-[0.04em] text-kyoto-sub">
              {item.institutionUrl ? (
                <a
                  href={item.institutionUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-kyoto-accent transition-colors duration-300"
                >
                  {item.institution}
                </a>
              ) : (
                item.institution
              )}
            </p>
            {item.details && (
              <p class="m-0 mt-2 text-[0.84rem] leading-[1.5] text-kyoto-text/75">{item.details}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <div class="border-t border-shibui md:border-t-0 md:border-l-shibui mt-6 md:mt-0 pt-6 md:pt-0 md:pl-10">
      <h3 class="section-kicker mb-5">Zertifizierungen</h3>
      <ul class="m-0 p-0 flex flex-col gap-3">
        {certifications.map((cert) => (
          <li class="list-none font-sans text-[0.88rem] leading-[1.5] text-kyoto-text/80">{cert.title}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
