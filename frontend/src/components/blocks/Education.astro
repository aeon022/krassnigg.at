---
import type { CollectionEntry } from "astro:content";

interface Props {
  degrees: CollectionEntry<"education">[];
  certifications: CollectionEntry<"certifications">[];
}

const { degrees = [], certifications = [] } = Astro.props as Props;
const basePath = import.meta.env.BASE_URL || "/";
const withBase = (path: string) => {
  const normalized = path.startsWith("/") ? path.slice(1) : path;
  if (basePath === "/") return `/${normalized}`;
  return `${basePath}${normalized}`;
};
---

<section id="education" class="mt-20 border-t border-shibui pt-10">
  <h2 class="section-kicker mb-6">Ausbildung</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-0">
    <!-- Degrees -->
    <div>
      {degrees.map((item, i) => (
        <div class={`grid grid-cols-[56px_1fr] gap-6 py-5 ${i < degrees.length - 1 ? 'border-b border-shibui' : ''}`}>
          <p class="m-0 font-sans text-[11px] tracking-[0.1em] text-kyoto-sub font-semibold pt-0.5">{item.data.year}</p>
          <div>
            <p class="m-0 font-serif text-[clamp(0.95rem,1.4vw,1.1rem)] leading-[1.25]">
              <a href={withBase(`/education/${item.id}`)} class="hover:text-kyoto-accent transition-colors duration-300">
                {item.data.degree}
              </a>
            </p>
            <p class="m-0 mt-1 font-sans text-[0.8rem] tracking-[0.04em] text-kyoto-sub">
              {item.data.institutionUrl ? (
                <a
                  href={item.data.institutionUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-kyoto-accent transition-colors duration-300"
                >
                  {item.data.institution}
                </a>
              ) : (
                item.data.institution
              )}
            </p>
            {item.data.details && (
              <p class="m-0 mt-2 text-[0.84rem] leading-[1.5] text-kyoto-text/75">{item.data.details}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Certifications -->
    <div class="border-t border-shibui md:border-t-0 md:border-l-shibui mt-6 md:mt-0 pt-6 md:pt-0 md:pl-10">
      <h3 class="section-kicker mb-5">Zertifizierungen</h3>
      <ul class="m-0 p-0 flex flex-col gap-3">
        {certifications.map((cert) => (
          <li class="list-none font-sans text-[0.88rem] leading-[1.5] text-kyoto-text/80">
            <a href={withBase(`/certifications/${cert.id}`)} class="hover:text-kyoto-accent transition-colors duration-300">
              {cert.data.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
